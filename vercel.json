{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "crons": [
    { "path": "/api/cron/agents", "schedule": "0 9 * * *" },
    { "path": "/api/cron/upsell", "schedule": "0 10 * * *" },
    { "path": "/api/cron/contracts", "schedule": "0 11 * * *" }
  ]
}
