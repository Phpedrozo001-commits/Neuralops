{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/agents",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/upsell",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/contracts",
      "schedule": "0 */6 * * *"
    }
  ]
}
