# ============================================
# NeuralOps - Environment Variables Setup
# ============================================
# IMPORTANT: Add these variables to Vercel dashboard
# Settings > Environment Variables
# See ENV_SETUP_GUIDE.md for detailed instructions

# ============================================
# 🗄️ DATABASE CONFIGURATION (REQUIRED)
# ============================================
# Get from Supabase: Settings > Database > Connection string (Node.js)
# Example: postgresql://postgres:PASSWORD@db.REGION.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.region.supabase.co:5432/postgres

# ============================================
# 🔑 AUTHENTICATION (REQUIRED)
# ============================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_here_at_least_32_characters_long
JWT_EXPIRY=7d

# ============================================
# 🤖 AI & LLM CONFIGURATION (OPTIONAL)
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ============================================
# 🌍 ENVIRONMENT
# ============================================
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://neuralops-sage.vercel.app

# ============================================
# ⚙️ AGENT CONFIGURATION
# ============================================
# Risk thresholds (0-100)
CHURN_RISK_THRESHOLD=40
UPSELL_CONFIDENCE_THRESHOLD=60
CONTRACT_DEVIATION_THRESHOLD=10

# ============================================
# 📧 EMAIL SERVICE (OPTIONAL)
# ============================================
# For sending retention emails, upsell offers, etc
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# 🔔 SLACK INTEGRATION (OPTIONAL)
# ============================================
# Get from: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# 📊 LOGGING & MONITORING
# ============================================
LOG_LEVEL=info

# ============================================
# 🔐 SECURITY - CORS
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://neuralops-sage.vercel.app

# ============================================
# 🔌 MANUS INTEGRATION (OPTIONAL)
# ============================================
BUILT_IN_FORGE_API_KEY=your_manus_api_key
BUILT_IN_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your_manus_frontend_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Copy DATABASE_URL and JWT_SECRET values
# 2. Go to: https://vercel.com/neural-ops-projects/neuralops
# 3. Click Settings > Environment Variables
# 4. Add each variable with its value
# 5. Select all environments (Production, Preview, Development)
# 6. Click Redeploy
# 7. Test: curl https://neuralops-sage.vercel.app/api/health
#
# See ENV_SETUP_GUIDE.md for detailed step-by-step instructions
