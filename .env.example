# NeuralOps Backend Configuration

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=./neuralops.db

# Security - JWT
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_EXPIRY=7d

# Agents Configuration
CHURN_RISK_THRESHOLD=40
UPSELL_CONFIDENCE_THRESHOLD=60
CONTRACT_DEVIATION_THRESHOLD=10

# Email Service (optional - for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Slack Integration (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Logging
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://neuralops-sage.vercel.app
